{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@phozart/phz-shared": ["../shared/src/index.ts"],
      "@phozart/phz-shared/adapters": ["../shared/src/adapters/index.ts"],
      "@phozart/phz-shared/types": ["../shared/src/types/index.ts"],
      "@phozart/phz-shared/design-system": ["../shared/src/design-system/index.ts"],
      "@phozart/phz-shared/artifacts": ["../shared/src/artifacts/index.ts"],
      "@phozart/phz-shared/coordination": ["../shared/src/coordination/index.ts"],
      "@phozart/phz-shared/definitions": ["../shared/src/definitions/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "src/__tests__"],
  "references": [
    { "path": "../core" },
    { "path": "../criteria" },
    { "path": "../engine" },
    { "path": "../shared" }
  ]
}

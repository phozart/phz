{
  "name": "@phozart/phz-widgets",
  "version": "0.1.0",
  "description": "Lit Web Component widgets — KPI cards, charts, scorecards, dashboards",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": ["dist/**/*.js"],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "author": "phozart",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=20" },
  "keywords": ["widgets", "kpi-card", "bar-chart", "dashboard", "web-components", "lit"],
  "repository": {
    "type": "git",
    "url": "https://github.com/phozart/phz-grid.git",
    "directory": "packages/widgets"
  },
  "bugs": {
    "url": "https://github.com/phozart/phz-grid/issues"
  },
  "homepage": "https://github.com/phozart/phz-grid/tree/main/packages/widgets#readme",
  "dependencies": {
    "@phozart/phz-core": "^0.1.0",
    "@phozart/phz-engine": "^0.1.0",
    "lit": "^3.2.0"
  }
}

{
  "name": "@phozart/widgets",
  "version": "0.1.0",
  "description": "Lit Web Component widgets — KPI cards, charts, scorecards, dashboards",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": [
    "dist/components/phz-kpi-card.js",
    "dist/components/phz-kpi-scorecard.js",
    "dist/components/phz-bar-chart.js",
    "dist/components/phz-trend-line.js",
    "dist/components/phz-bottom-n.js",
    "dist/components/phz-status-table.js",
    "dist/components/phz-drill-link.js",
    "dist/components/phz-dashboard.js",
    "dist/components/phz-view-manager.js",
    "dist/components/phz-selection-bar.js",
    "dist/components/phz-widget.js",
    "dist/components/phz-pie-chart.js",
    "dist/components/phz-line-chart.js",
    "dist/components/phz-area-chart.js",
    "dist/components/phz-gauge.js",
    "dist/components/phz-scatter-chart.js",
    "dist/components/phz-heatmap.js",
    "dist/components/phz-waterfall-chart.js",
    "dist/components/phz-funnel-chart.js",
    "dist/components/phz-slicer.js",
    "dist/components/phz-export-menu.js",
    "dist/components/phz-alert-panel.js",
    "dist/components/phz-query-builder.js",
    "dist/components/phz-decision-tree.js",
    "dist/components/phz-container-box.js",
    "dist/components/phz-rich-text.js",
    "dist/themes.js",
    "dist/annotations.js",
    "dist/components/phz-chart.js"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "author": "phozart",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "widgets",
    "kpi-card",
    "bar-chart",
    "dashboard",
    "web-components",
    "lit"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/phozart/phz-grid.git",
    "directory": "packages/widgets"
  },
  "bugs": {
    "url": "https://github.com/phozart/phz-grid/issues"
  },
  "homepage": "https://github.com/phozart/phz-grid/tree/main/packages/widgets#readme",
  "dependencies": {
    "@phozart/core": "^0.1.0",
    "@phozart/engine": "^0.1.0",
    "lit": "^3.2.0"
  }
}

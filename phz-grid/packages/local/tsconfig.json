{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "src",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "lib": ["ES2022"],
    "paths": {
      "@phozart/shared/definitions": ["../shared/src/definitions/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "src/__tests__"],
  "references": [
    { "path": "../shared" },
    { "path": "../workspace" },
    { "path": "../engine" }
  ]
}

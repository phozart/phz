{
  "name": "@phozart/core",
  "version": "0.1.0",
  "description": "Headless grid engine — data model, state, events",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "author": "phozart",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=20" },
  "keywords": ["data-grid", "headless", "table", "state-management", "typescript"],
  "repository": {
    "type": "git",
    "url": "https://github.com/phozart/phz-grid.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/phozart/phz-grid/issues"
  },
  "homepage": "https://github.com/phozart/phz-grid/tree/main/packages/core#readme"
}

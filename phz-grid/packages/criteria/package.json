{
  "name": "@phozart/phz-criteria",
  "version": "0.1.0",
  "description": "Selection Criteria panel — date ranges, tree selects, presets, admin",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shared-styles": {
      "types": "./dist/shared-styles.d.ts",
      "import": "./dist/shared-styles.js"
    }
  },
  "sideEffects": ["dist/**/*.js"],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "author": "phozart",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=20" },
  "keywords": ["selection-criteria", "filters", "date-range", "tree-select", "web-components", "lit"],
  "repository": {
    "type": "git",
    "url": "https://github.com/phozart/phz-grid.git",
    "directory": "packages/criteria"
  },
  "bugs": {
    "url": "https://github.com/phozart/phz-grid/issues"
  },
  "homepage": "https://github.com/phozart/phz-grid/tree/main/packages/criteria#readme",
  "dependencies": {
    "@phozart/phz-core": "^0.1.0",
    "@phozart/phz-engine": "^0.1.0",
    "lit": "^3.2.0"
  },
  "peerDependencies": {
    "@phozart/phz-workspace": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@phozart/phz-workspace": {
      "optional": true
    }
  }
}

{
  "name": "@phozart/shared",
  "version": "0.1.0",
  "description": "Shared infrastructure — adapter interfaces, design system, artifact types, runtime coordination",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./design-system": {
      "types": "./dist/design-system/index.d.ts",
      "import": "./dist/design-system/index.js"
    },
    "./artifacts": {
      "types": "./dist/artifacts/index.d.ts",
      "import": "./dist/artifacts/index.js"
    },
    "./coordination": {
      "types": "./dist/coordination/index.d.ts",
      "import": "./dist/coordination/index.js"
    },
    "./definitions": {
      "types": "./dist/definitions/index.d.ts",
      "import": "./dist/definitions/index.js"
    }
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "zod": { "optional": true }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "author": "phozart",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=20" },
  "keywords": ["shared", "adapters", "design-system", "types", "typescript"],
  "repository": {
    "type": "git",
    "url": "https://github.com/phozart/phz-grid.git",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/phozart/phz-grid/issues"
  },
  "homepage": "https://github.com/phozart/phz-grid/tree/main/packages/shared#readme"
}

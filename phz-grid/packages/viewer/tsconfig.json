{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "src",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@phozart/shared": ["../shared/src/index.ts"],
      "@phozart/shared/adapters": ["../shared/src/adapters/index.ts"],
      "@phozart/shared/types": ["../shared/src/types/index.ts"],
      "@phozart/shared/coordination": ["../shared/src/coordination/index.ts"],
      "@phozart/shared/artifacts": ["../shared/src/artifacts/index.ts"],
      "@phozart/shared/design-system": ["../shared/src/design-system/index.ts"],
      "@phozart/engine/explorer": ["../engine/src/explorer/index.ts"],
      "@phozart/engine": ["../engine/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "src/__tests__"],
  "references": [
    { "path": "../shared" },
    { "path": "../core" },
    { "path": "../engine" },
    { "path": "../grid" },
    { "path": "../widgets" }
  ]
}

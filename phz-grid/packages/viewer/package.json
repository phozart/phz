{
  "name": "@phozart/viewer",
  "version": "0.1.0",
  "description": "Read-only consumption shell — catalog, dashboards, reports, explorer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "sideEffects": [
    "dist/components/*.js"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "author": "phozart",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=20" },
  "keywords": ["viewer", "shell", "dashboard", "report", "catalog", "read-only"],
  "repository": {
    "type": "git",
    "url": "https://github.com/phozart/phz-grid.git",
    "directory": "packages/viewer"
  },
  "bugs": {
    "url": "https://github.com/phozart/phz-grid/issues"
  },
  "homepage": "https://github.com/phozart/phz-grid/tree/main/packages/viewer#readme",
  "dependencies": {
    "@phozart/shared": "^0.1.0",
    "@phozart/core": "^0.1.0",
    "@phozart/engine": "^0.1.0",
    "@phozart/grid": "^0.1.0",
    "@phozart/widgets": "^0.1.0",
    "lit": "^3.2.0"
  },
  "peerDependencies": {
    "@lit/react": "^1.0.8",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@lit/react": { "optional": true },
    "react": { "optional": true }
  }
}

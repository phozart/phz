{
  "name": "phz-grid-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Next-generation universal data grid built on Web Components",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/phozart/phz-grid.git"
  },
  "bugs": {
    "url": "https://github.com/phozart/phz-grid/issues"
  },
  "homepage": "https://github.com/phozart/phz-grid#readme",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:ordered",
    "build:ordered": "npm run build -w packages/core && npm run build -w packages/shared && npm run build -w packages/engine && npm run build -w packages/duckdb && npm run build -w packages/grid && npm run build -w packages/criteria && npm run build -w packages/widgets && npm run build -w packages/workspace && npm run build -w packages/ai && npm run build -w packages/collab && npm run build -w packages/viewer && npm run build -w packages/editor && npm run build -w packages/local && npm run build -w packages/react && npm run build -w packages/vue && npm run build -w packages/angular",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "size": "node scripts/bundle-size.cjs",
    "typecheck": "tsc --build",
    "lint": "eslint packages/*/src/**/*.ts",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "clean": "rm -rf packages/*/dist tsconfig.tsbuildinfo packages/*/tsconfig.tsbuildinfo",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "dev:api": "npm run dev -w packages/api",
    "dev:demo": "npm run dev -w packages/demo",
    "dev:all": "concurrently -n api,demo -c blue,green \"npm:dev:api\" \"npm:dev:demo\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@rollup/rollup-darwin-arm64": "^4.59.0",
    "@size-limit/file": "^12.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "happy-dom": "^20.8.3",
    "prettier": "^3.4.0",
    "size-limit": "^12.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "zod": "^3.25.76"
  }
}
